<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <title><%= content_for?(:title) ? yield(:title) : "Standup Bot" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Tailwind via CDN for simplicity — swap for tailwindcss-rails in production %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: { 50: '#f0f9ff', 500: '#0ea5e9', 600: '#0284c7', 700: '#0369a1' }
            }
          }
        }
      }
    </script>

    <style>
      /* Markdown-rendered content styling */
      .prose h1, .prose h2, .prose h3 { font-weight: 600; margin-top: 1.25rem; margin-bottom: 0.5rem; }
      .prose h1 { font-size: 1.5rem; }
      .prose h2 { font-size: 1.25rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 0.25rem; }
      .prose h3 { font-size: 1.1rem; }
      .prose p { margin-bottom: 0.75rem; }
      .prose ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 0.75rem; }
      .prose li { margin-bottom: 0.25rem; }
      .prose strong { font-weight: 600; }
      .prose code { background: #f1f5f9; padding: 0.1rem 0.3rem; border-radius: 0.25rem; font-size: 0.875rem; }
      .prose hr { border-color: #e5e7eb; margin: 1rem 0; }
    </style>
  </head>
  <body class="bg-gray-50 min-h-screen">

    <!-- Navigation -->
    <nav class="bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="<%= root_path %>" class="flex items-center gap-2 font-semibold text-gray-800 text-lg">
          <span class="text-2xl">📋</span>
          <span>Standup Bot</span>
          <% if @current_team %>
            <span class="text-gray-400 font-normal text-sm">· <%= @current_team.name %></span>
          <% end %>
        </a>
        <div class="flex items-center gap-4 text-sm">
          <%= link_to "Submit Update", new_standup_entry_path,
              class: "text-gray-600 hover:text-brand-600 transition-colors" %>
          <%= link_to "Today's Entries", standup_entries_path,
              class: "text-gray-600 hover:text-brand-600 transition-colors" %>
        </div>
      </div>
    </nav>

    <!-- Flash messages -->
    <% if notice %>
      <div class="max-w-4xl mx-auto px-4 pt-4">
        <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 flex items-start gap-2">
          <span class="mt-0.5">✅</span>
          <p class="text-sm"><%= notice %></p>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="max-w-4xl mx-auto px-4 pt-4">
        <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 flex items-start gap-2">
          <span class="mt-0.5">⚠️</span>
          <p class="text-sm"><%= alert %></p>
        </div>
      </div>
    <% end %>

    <!-- Main content -->
    <main class="max-w-4xl mx-auto px-4 py-8">
      <%= yield %>
    </main>

    <footer class="border-t border-gray-200 mt-12">
      <div class="max-w-4xl mx-auto px-4 py-4 text-xs text-gray-400 text-center">
        Standup Bot · Powered by Claude
      </div>
    </footer>

  </body>
</html>
